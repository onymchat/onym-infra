# Copy to .env and fill in. Consumed by deploy/digitalocean/deploy.sh
# (DO/CF tokens) and by docker compose (hostnames + Caddy email).
# deploy.sh uploads ONLY the compose-relevant vars to the droplet —
# the DO/CF tokens stay local.

# --- Credentials (local only, never uploaded) ---
# DigitalOcean API token (doctl).
DO_API_KEY=
# Cloudflare API token with DNS:Edit on the onym.app zone.
CF_API_TOKEN=

# --- Domain / hostnames (uploaded; consumed by Caddy) ---
DOMAIN=onym.app
NOSTR_HOST=nostr.onym.app
BLOSSOM_HOST=blossom.onym.app
RELAYER_HOST=relayer.onym.app

# Email for the Let's Encrypt account (cert-expiry notices).
CADDY_EMAIL=rinat@qda.one

# --- Droplet ---
DO_REGION=ams3
DO_DROPLET_SIZE=s-1vcpu-2gb
SSH_KEY_PATH=$HOME/.ssh/id_ed25519

# Populated by deploy.sh after the first run so re-runs reuse the box.
DROPLET_ID=
DROPLET_IP=
