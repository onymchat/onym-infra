# Copy to relayer.env and fill in. Mounted into the relayer container
# via docker-compose `env_file`. Never committed (see .gitignore).
# RELAYER_BIND is set by docker-compose (0.0.0.0:8080) — don't set it
# here. Mirror of the runtime vars from onym-relayer/.env.example.

# Stellar secret key (S...) the relayer signs transactions with. REQUIRED.
RELAYER_SECRET_KEY=

# Comma-separated bearer tokens. Empty disables auth on `/`. The iOS
# client sends one of these as `Authorization: Bearer <token>`, so if
# you set this, the app's relayer auth token must match.
RELAYER_AUTH_TOKENS=

# Per-network Soroban RPC endpoints (Stellar public infra by default).
RELAYER_TESTNET_RPC_URL=https://soroban-testnet.stellar.org
RELAYER_PUBLIC_RPC_URL=https://soroban.stellar.org

# Network passphrases.
RELAYER_TESTNET_NETWORK_PASSPHRASE='Test SDF Network ; September 2015'
RELAYER_PUBLIC_NETWORK_PASSPHRASE='Public Global Stellar Network ; September 2015'

# Allowlist is fetched from the onym-contracts cumulative manifest on
# startup + on a timer; leave these at defaults unless testing a fork.
RELAYER_CONTRACTS_MANIFEST_URL=https://github.com/onymchat/onym-contracts/releases/latest/download/contracts-manifest.json
RELAYER_CONTRACTS_MANIFEST_REFRESH_SECS=900

# Guardrails.
RELAYER_RATE_LIMIT=120
RELAYER_MAX_PAYLOAD_SIZE=8192
